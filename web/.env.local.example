# Supabase project settings (Project Settings → API)
# Client-safe (shipped to the browser — anon key, RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Server-only (Netlify Functions, Supabase admin, Python CLI)
# Full access — bypasses RLS. Never commit, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=ey...
